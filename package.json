{
  "name": "restaurant-app",
  "private": true,
  "version": "1.0.0",
  "description": "Smart Restaurant - Full Stack Application",
  "scripts": {
    "install-all": "npm install && cd client && npm install --legacy-peer-deps && cd ../server && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
